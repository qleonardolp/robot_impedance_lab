            <friction>
              <ode/>
            </friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name='push_object_visual'>
          <geometry>
            <box>
              <size>0.20 0.60 0.40</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0 0.40 1.0</ambient>
            <diffuse>0.80 0 0.40 0.88</diffuse>
            <specular>1 1 1 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <enable_wind>false</enable_wind>
      </link>
      <static>false</static>
    </model>
    <light name='sun' type='directional'>
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>1</intensity>
      <direction>0.5 0.10 -0.90</direction>
      <diffuse>0.80 0.80 0.80 1</diffuse>
