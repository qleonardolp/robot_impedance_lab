<sdf version='1.10'>
  <world name='Waterworld'>
    <physics name='default_physics' type='dart'>
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>500</real_time_update_rate>
      <dart>
        <collision_detector>bullet</collision_detector>
      </dart>
    </physics>
    <plugin name='gz::sim::systems::Physics' filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands' filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact' filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::ForceTorque' filename='gz-sim-forcetorque-system'/>
    <gravity>0.0 0.00 -9.80665</gravity>
    <magnetic_field>1.83535e-05 -7.7993e-06 -1.46974e-05</magnetic_field>
    <atmosphere type='adiabatic'/>
    <scene>
      <ambient>0.40 0.40 0.40 1</ambient>
      <background>0.70 0.69 0.69 1</background>
      <shadows>false</shadows>
    </scene>
    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode/>
            </friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.800000012 0.800000012 0.800000012 1</ambient>
            <diffuse>0.800000012 0.800000012 0.800000012 1</diffuse>
            <specular>0.800000012 0.800000012 0.800000012 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>1</iyy>
            <iyz>0</iyz>
            <izz>1</izz>
          </inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <pose>0 0 0 0 0 0</pose>
      <self_collide>false</self_collide>
    </model>
    <model name='rigid_table'>
      <pose>0.0 2.10 0.20 0 0 0</pose>
      <link name='rigid_table_link'>
        <inertial>
          <inertia>
            <ixx>1</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>1</iyy>
            <iyz>0</iyz>
            <izz>1</izz>
          </inertia>
          <mass>1</mass>
          <pose>0 0 0 0 0 0</pose>
        </inertial>
        <collision name='rigid_table_collision'>
          <geometry>
            <box>
              <size>0.70 1.40 0.40</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.4</mu>
                <mu2>0.4</mu2>
              </ode>
            </friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name='rigid_table_visual'>
          <geometry>
            <box>
              <size>0.70 1.40 0.40</size>
            </box>
          </geometry>
          <material>
            <ambient>0.20 1.0 1.0 1.0</ambient>
            <diffuse>0.20 1.0 1.0 0.80</diffuse>
            <specular>1 1 1 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
      </link>
      <static>true</static>
    </model>
    <model name='push_object'>
      <pose>0.0 1.83 0.60 0 0 0</pose>
      <link name='push_object_link'>
        <inertial>
          <inertia>
            <ixx>0.0433332</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0166666</iyy>
            <iyz>0</iyz>
            <izz>0.0333332</izz>
          </inertia>
          <mass>1.0</mass>
          <pose>0 0 0 0 0 0</pose>
        </inertial>
        <collision name='push_object_collision'>
          <geometry>
            <box>
              <size>0.20 0.60 0.40</size>
            </box>
          </geometry>
